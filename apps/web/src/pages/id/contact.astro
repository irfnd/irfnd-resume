---
import ContactForm from '@/components/ui/ContactForm.astro';
import MapEmbed from '@/components/ui/MapEmbed.astro';
import Toast from '@/components/ui/Toast.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl } from '@/utils/language';
import { contact as contactCollection, contactForm, getByLang, ui } from '@irfnd/data';

const lang = getLangFromUrl(Astro.url);
const contactMe = getByLang(contactForm, lang);
const contactItems = getByLang(contactCollection, lang).items;
const { seo } = getByLang(ui, lang);

const directContact = contactItems.filter((c) => c.showInContactPage).map((c) => ({ label: c.label, url: c.url, icon: c.icon }));
---

<BaseLayout title={seo.contact.title} description={seo.contact.description}>
	<section data-gsap-slide-up>
		<div class='mb-8'>
			<h1 class='text-foreground text-2xl font-bold tracking-tight'>{contactMe.header}</h1>
			<p class='text-muted-foreground mt-2 max-w-2xl text-sm leading-relaxed'>{contactMe.description}</p>
		</div>

		<ContactForm
			formFields={contactMe.form}
			contactMe={{
				formTitle: contactMe.formTitle,
				submitButton: contactMe.submitButton,
				submittingButton: contactMe.submittingButton,
				successMessage: contactMe.successMessage,
				sendAnotherMessage: contactMe.sendAnotherMessage,
				errors: contactMe.errors,
				reachMeDirectly: contactMe.reachMeDirectly,
			}}
			validation={contactMe.validation}
			directContact={directContact}
		>
			<MapEmbed slot='map' />
		</ContactForm>
	</section>

	<Toast />
</BaseLayout>

<script src='@/scripts/contact-form.ts'></script>
