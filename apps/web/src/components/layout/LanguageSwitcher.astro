---
import { getLangFromUrl, languages } from '@/utils/language';
import { getByLang, ui } from '@irfnd/data';
import { Icon } from 'astro-icon/components';

const lang = getLangFromUrl(Astro.url);
const { common } = getByLang(ui, lang);
const currentLang = languages.find((l) => l.code === lang);
const label = common.changeLanguage;
---

<div class='relative'>
	<button
		data-lang-toggle
		class='bg-background/80 border-border/60 text-muted-foreground light-shadow flex cursor-pointer items-center gap-2 rounded-full border p-2.5 ring ring-transparent backdrop-blur-md transition-all duration-300 outline-none hover:border-blue-200 hover:text-blue-600 hover:ring-blue-100 focus-visible:border-blue-300 focus-visible:ring focus-visible:ring-blue-400 dark:shadow-none dark:hover:border-blue-900 dark:hover:text-blue-400 dark:hover:ring-blue-900/20 dark:focus-visible:border-blue-600 dark:focus-visible:ring-blue-500'
		aria-label={label}
		title={label}
	>
		<span class='leading-0 font-medium'>{currentLang?.flag}</span>
		<Icon name='tabler:selector' class='size-4' />
	</button>

	<div
		data-lang-dropdown
		class='bg-popover/95 border-border/60 light-shadow absolute top-full right-0 z-65 mt-2 hidden w-42 rounded-2xl border p-2 backdrop-blur-md dark:shadow-lg'
	>
		<div class='flex flex-col gap-1'>
			{
				languages.map((l) => (
					<button
						data-lang-option={l.code}
						class:list={[
							'hover:bg-muted hover:text-foreground relative flex w-full cursor-pointer items-center gap-2 rounded-xl px-4 py-2 text-left text-sm transition-colors outline-none',
							l.code === lang ? 'dark:text-foreground bg-blue-50 text-blue-600 dark:bg-blue-500/10' : 'text-muted-foreground',
						]}
					>
						<span>{l.flag}</span>
						<span class='flex-1'>{l.label}</span>
						{l.code === lang && <Icon name='tabler:check' class='size-4 text-blue-600 dark:text-blue-400' />}
					</button>
				))
			}
		</div>
	</div>
</div>
