---
import { getLangFromUrl } from '@/utils/language';
import { getByLang, ui } from '@irfnd/data';
import { Icon } from 'astro-icon/components';

const lang = getLangFromUrl(Astro.url);
const { common } = getByLang(ui, lang);
const label = common.changeTheme;
---

<button
	data-theme-toggle
	class='bg-background/80 border-border/60 text-muted-foreground light-shadow cursor-pointer rounded-full border p-2.5 ring-1 ring-transparent backdrop-blur-md transition-all duration-300 outline-none hover:border-blue-200 hover:text-blue-600 hover:ring-blue-100 focus-visible:border-blue-300 focus-visible:ring focus-visible:ring-blue-400 dark:shadow-none dark:hover:border-blue-900 dark:hover:text-blue-400 dark:hover:ring-blue-900/20 dark:focus-visible:border-blue-600 dark:focus-visible:ring-blue-500'
	aria-label={label}
	title={label}
>
	<Icon name='tabler:sun' class='hidden size-4 dark:block' />
	<Icon name='tabler:moon' class='block size-4 dark:hidden' />
</button>
