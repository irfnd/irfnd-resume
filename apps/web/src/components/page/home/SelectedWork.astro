---
import ProjectCard from '@/components/ui/ProjectCard.astro';
import ProjectDialog from '@/components/ui/ProjectDialog.astro';
import ProjectDialogShell from '@/components/ui/ProjectDialogShell.astro';
import { cn } from '@/utils/cn';
import { getLangFromUrl, getLocalizedPath } from '@/utils/language';
import { getByLang, portfolio as portfolioCollection, resolveTechStacks, techStacks, ui } from '@irfnd/data';
import { Icon } from 'astro-icon/components';

const lang = getLangFromUrl(Astro.url);
const portfolioData = getByLang(portfolioCollection, lang);
const { common } = getByLang(ui, lang);
const allStacks = techStacks.stacks;

const commonLabels = { source: common.source, liveDemo: common.liveDemo, internal: common.internal };

const selectedProjects = portfolioData.projects
	.filter((project) => project.isSelected)
	.sort((a, b) => a.name.localeCompare(b.name))
	.map((project) => ({ ...project, stacks: resolveTechStacks(allStacks, project.stacks) }));
---

<section data-gsap-slide-up>
	<div class='mb-8 flex items-center justify-between'>
		<h2 class='text-foreground text-lg font-semibold tracking-tight'>{portfolioData.title}</h2>
		<div class='bg-border mx-6 h-px flex-1'></div>
		<a
			href={getLocalizedPath(lang, '/portfolio')}
			class='flex shrink-0 items-center gap-1 rounded-sm text-xs font-medium text-slate-600 transition-colors outline-none hover:text-blue-600 focus-visible:ring focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:hover:text-white dark:focus-visible:ring-blue-500 dark:focus-visible:ring-offset-neutral-900'
		>
			{common.viewMore}
			<Icon name='tabler:arrow-right' class='size-3' />
		</a>
	</div>

	<div class='grid grid-cols-1 gap-4 md:grid-cols-2' data-gsap-stagger>
		{
			selectedProjects.map((project, index) => (
				<div class={cn('flex h-full flex-col', index === 0 ? 'md:col-span-2' : '')}>
					<ProjectCard {...project} isFirst={index === 0} commonLabels={commonLabels} dialogId={`project-dialog-${index}`} />
				</div>
			))
		}
	</div>

	{
		selectedProjects.map((project, index) => (
			<ProjectDialog {...project} commonLabels={commonLabels} dialogId={`project-dialog-${index}`} />
		))
	}

	<ProjectDialogShell />
</section>

<script src='@/scripts/project-dialog.ts'></script>
