---
import TechIcon from '@/components/ui/TechIcon.astro';
import { getLangFromUrl } from '@/utils/language';
import { getByLang, resolveTechStacks, technology as technologyCollection, techStacks } from '@irfnd/data';

const lang = getLangFromUrl(Astro.url);
const technology = getByLang(technologyCollection, lang);
const allStacks = techStacks.stacks;

const stackEntries = Object.entries(technology.stacks)
	.filter(([, labels]) => labels.length > 0)
	.map(([category, labels]) => [category, resolveTechStacks(allStacks, labels)] as const);
---

<section data-gsap-slide-up>
	<div class="flex items-center justify-between mb-8">
		<h2 class="text-lg font-semibold text-foreground tracking-tight">{technology.title}</h2>
		<div class="h-px bg-border flex-1 ml-6"></div>
	</div>

	<div
		class="glass-card bg-white/60 dark:bg-white/5 border border-white/50 dark:border-white/5 rounded-2xl p-8 light-shadow dark:shadow-none"
	>
		<div class="space-y-8">
			{
				stackEntries.map(([category, techs], index) => (
					<>
						<div>
							<h3 class="text-xs font-semibold text-slate-400 dark:text-neutral-400 uppercase tracking-widest mb-6">
								{category}
							</h3>
							<div
								class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4"
								data-gsap-stagger
							>
								{techs.map((tech) => (
									<TechIcon {...tech} withLabel />
								))}
							</div>
						</div>
						{index < stackEntries.length - 1 && <div class="h-px bg-border w-full" />}
					</>
				))
			}
		</div>
	</div>
</section>
