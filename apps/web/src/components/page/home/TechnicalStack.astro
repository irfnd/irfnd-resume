---
import TechIcon from '@/components/ui/TechIcon.astro';
import { getLangFromUrl } from '@/utils/language';
import { getByLang, resolveTechStacks, technology as technologyCollection, techStacks } from '@irfnd/data';

const lang = getLangFromUrl(Astro.url);
const technology = getByLang(technologyCollection, lang);
const allStacks = techStacks.stacks;

const stackEntries = Object.entries(technology.stacks)
	.filter(([, labels]) => labels.length > 0)
	.map(([category, labels]) => [category, resolveTechStacks(allStacks, labels)] as const);
---

<section data-gsap-slide-up>
	<div class='mb-8 flex items-center justify-between'>
		<h2 class='text-foreground text-lg font-semibold tracking-tight'>{technology.title}</h2>
		<div class='bg-border ml-6 h-px flex-1'></div>
	</div>

	<div
		class='glass-card light-shadow rounded-2xl border border-white/50 bg-white/60 p-8 dark:border-white/5 dark:bg-white/5 dark:shadow-none'
	>
		<div class='space-y-8'>
			{
				stackEntries.map(([category, techs], index) => (
					<>
						<div>
							<h3 class='mb-6 text-xs font-semibold tracking-widest text-slate-400 uppercase dark:text-neutral-400'>
								{category}
							</h3>
							<div class='grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5' data-gsap-stagger>
								{techs.map((tech) => (
									<TechIcon {...tech} withLabel />
								))}
							</div>
						</div>
						{index < stackEntries.length - 1 && <div class='bg-border h-px w-full' />}
					</>
				))
			}
		</div>
	</div>
</section>
