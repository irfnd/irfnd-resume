---
import HighlightText from '@/components/ui/HighlightText.astro';
import TechIcon from '@/components/ui/TechIcon.astro';
import TimelineBadge from '@/components/ui/TimelineBadge.astro';
import TimelineBeam from '@/components/ui/TimelineBeam.astro';
import TimelineDot from '@/components/ui/TimelineDot.astro';
import TimelineItem from '@/components/ui/TimelineItem.astro';
import { cn } from '@/utils/cn';
import { getLangFromUrl } from '@/utils/language';
import { experience as experienceCollection, getByLang, resolveTechStacks, techStacks } from '@irfnd/data';
import { Icon } from 'astro-icon/components';

const lang = getLangFromUrl(Astro.url);
const experienceData = getByLang(experienceCollection, lang);
const allStacks = techStacks.stacks;

const experience = {
	...experienceData,
	jobs: experienceData.jobs.map((job) => ({
		...job,
		descriptions: job.descriptions.map((desc) => ({
			...desc,
			stacks: resolveTechStacks(allStacks, desc.stacks),
		})),
	})),
};
---

<section data-gsap-slide-up>
	<div class='mb-8 flex items-center justify-between'>
		<h2 class='text-foreground text-lg font-semibold tracking-tight'>{experience.title}</h2>
		<div class='bg-border ml-6 h-px flex-1'></div>
	</div>

	<TimelineBeam class='ml-3 space-y-12 pb-4'>
		{
			experience.jobs.map((job) => (
				<TimelineItem class='relative pl-6 md:pl-10'>
					<TimelineDot />

					<div class='mb-4 flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between'>
						<div>
							<h3 class='text-foreground text-lg font-semibold tracking-tight'>{job.mainPosition}</h3>
							<div class='mt-1 flex flex-wrap items-center gap-1 md:gap-2'>
								{job.link ? (
									<a
										href={job.link}
										target='_blank'
										rel='noopener noreferrer'
										class='text-muted-foreground rounded text-sm font-medium transition-colors outline-none hover:text-blue-600 focus-visible:ring focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:hover:text-white dark:focus-visible:ring-blue-500 dark:focus-visible:ring-offset-neutral-900'
									>
										{job.company}
									</a>
								) : (
									<span class='text-muted-foreground text-sm font-medium'>{job.company}</span>
								)}
								<span class='text-xs text-slate-300 dark:text-neutral-700'>•</span>
								<span class='text-muted-foreground text-xs'>{job.type}</span>
							</div>
						</div>
						<TimelineBadge>{job.duration.join(' - ')}</TimelineBadge>
					</div>

					{job.descriptions.map((desc, descIndex) => (
						<div
							class={cn(
								'relative mb-6',
								job.descriptions.length > 1 &&
									descIndex === job.descriptions.length - 1 &&
									'border-border/60 mb-0 border-t border-dashed pt-6',
							)}
						>
							{job.descriptions.length > 1 && (
								<div class='mb-3 flex items-center gap-2'>
									{desc.icon && (
										<Icon
											name={desc.icon}
											class='text-muted-foreground size-3.5 group-hover:text-blue-700 group-data-active:text-blue-700 group-hover:dark:text-blue-400/90 group-data-active:dark:text-blue-400/90'
										/>
									)}
									<span class='text-xs font-bold tracking-wider text-slate-800 uppercase dark:text-white'>{desc.position}</span>
								</div>
							)}

							{desc.summary.map((summary) => (
								<p class='text-muted-foreground mb-4 text-sm leading-relaxed font-light'>
									<HighlightText text={summary.value} keywords={summary.keywords} />
								</p>
							))}

							{desc.points.length > 0 && (
								<ul class='mb-4 space-y-1'>
									{desc.points.slice(0, 3).map((point) => (
										<li class='text-muted-foreground inline-flex gap-3 text-sm leading-relaxed font-light'>
											<span class='mt-2 h-1 w-1 shrink-0 rounded-full bg-slate-400 text-slate-300 dark:bg-neutral-600 dark:text-neutral-600' />
											<span>
												<HighlightText text={point.value} keywords={point.keywords} class='font-semibold' />
											</span>
										</li>
									))}
								</ul>
							)}

							{desc.stacks.length > 0 && (
								<div class='flex flex-wrap gap-2'>
									{desc.stacks.map((stack) => (
										<TechIcon {...stack} class='rounded-md p-2 [&>svg]:size-4 md:[&>svg]:size-5' />
									))}
								</div>
							)}
						</div>
					))}
				</TimelineItem>
			))
		}
	</TimelineBeam>
</section>
