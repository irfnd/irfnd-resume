---
import { getLangFromUrl } from '@/i18n';
import { cn } from '@/utils/cn';
import { Icon } from 'astro-icon/components';
import { getByLang, experience as experienceCollection, techStacks, resolveTechStacks } from '@irfnd/data';
import type { LangCode } from '@irfnd/data';
import HighlightText from '@/components/ui/HighlightText.astro';
import TechIcon from '@/components/ui/TechIcon.astro';
import TimelineBeam from '@/components/ui/TimelineBeam.astro';
import TimelineItem from '@/components/ui/TimelineItem.astro';
import TimelineDot from '@/components/ui/TimelineDot.astro';
import TimelineBadge from '@/components/ui/TimelineBadge.astro';

const lang = getLangFromUrl(Astro.url);
const experienceData = getByLang(experienceCollection, lang as LangCode);
const allStacks = techStacks.stacks;

const experience = {
	...experienceData,
	jobs: experienceData.jobs.map((job) => ({
		...job,
		descriptions: job.descriptions.map((desc) => ({
			...desc,
			stacks: resolveTechStacks(allStacks, desc.stacks),
		})),
	})),
};
---

<section data-gsap-slide-up>
	<div class="flex items-center justify-between mb-8">
		<h2 class="text-lg font-semibold text-foreground tracking-tight">{experience.title}</h2>
		<div class="h-px bg-border flex-1 ml-6"></div>
	</div>

	<TimelineBeam class="ml-3 space-y-12 pb-4">
		{
			experience.jobs.map((job) => (
				<TimelineItem class="relative pl-6 md:pl-10">
					<TimelineDot />

					<div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-4 gap-2">
						<div>
							<h3 class="text-lg font-semibold text-foreground tracking-tight">{job.mainPosition}</h3>
							<div class="flex flex-wrap items-center gap-1 md:gap-2 mt-1">
								{job.link ? (
									<a
										href={job.link}
										target="_blank"
										rel="noopener noreferrer"
										class="text-sm text-muted-foreground hover:text-blue-600 dark:hover:text-white font-medium outline-none focus-visible:ring focus-visible:ring-blue-400 dark:focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-neutral-900 rounded transition-colors"
									>
										{job.company}
									</a>
								) : (
									<span class="text-sm text-muted-foreground font-medium">{job.company}</span>
								)}
								<span class="text-slate-300 dark:text-neutral-700 text-xs">•</span>
								<span class="text-xs text-muted-foreground">{job.type}</span>
							</div>
						</div>
						<TimelineBadge>{job.duration.join(' - ')}</TimelineBadge>
					</div>

					{job.descriptions.map((desc, descIndex) => (
						<div
							class={cn(
								'mb-6 relative',
								job.descriptions.length > 1 &&
									descIndex === job.descriptions.length - 1 &&
									'mb-0 pt-6 border-t border-dashed border-border/60',
							)}
						>
							{job.descriptions.length > 1 && (
								<div class="flex items-center gap-2 mb-3">
									{desc.icon && (
										<Icon
											name={desc.icon}
											class="size-3.5 text-muted-foreground group-hover:text-blue-700 group-hover:dark:text-blue-400/90 group-data-active:text-blue-700 group-data-active:dark:text-blue-400/90"
										/>
									)}
									<span class="text-xs font-bold text-slate-800 dark:text-white uppercase tracking-wider">
										{desc.position}
									</span>
								</div>
							)}

							{desc.summary.map((summary) => (
								<p class="text-sm text-muted-foreground font-light leading-relaxed mb-4">
									<HighlightText text={summary.value} keywords={summary.keywords} />
								</p>
							))}

							{desc.points.length > 0 && (
								<ul class="space-y-1 mb-4">
									{desc.points.slice(0, 3).map((point) => (
										<li class="inline-flex gap-3 text-sm text-muted-foreground font-light leading-relaxed">
											<span class="text-slate-300 dark:text-neutral-600 mt-2 h-1 w-1 shrink-0 rounded-full bg-slate-400 dark:bg-neutral-600" />
											<span>
												<HighlightText text={point.value} keywords={point.keywords} class="font-semibold" />
											</span>
										</li>
									))}
								</ul>
							)}

							{desc.stacks.length > 0 && (
								<div class="flex flex-wrap gap-2">
									{desc.stacks.map((stack) => (
										<TechIcon {...stack} class="[&>svg]:size-4 md:[&>svg]:size-5 p-2 rounded-md" />
									))}
								</div>
							)}
						</div>
					))}
				</TimelineItem>
			))
		}
	</TimelineBeam>
</section>
