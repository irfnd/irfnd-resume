---
import { getLangFromUrl } from '@/i18n';
import { about as aboutData, getByLang } from '@irfnd/data';
import type { LangCode } from '@irfnd/data';
import HighlightText from '@/components/ui/HighlightText.astro';
import { Icon } from 'astro-icon/components';

const lang = getLangFromUrl(Astro.url);
const about = getByLang(aboutData, lang as LangCode);
---

<section data-gsap-slide-up class="scroll-mt-24">
	<div class="flex items-center justify-between mb-8">
		<h2 class="text-lg font-semibold text-foreground tracking-tight">{about.title}</h2>
		<div class="h-px bg-border flex-1 ml-6"></div>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-3 gap-4" data-gsap-stagger>
		<div
			class="glass-card bg-white/60 dark:bg-white/5 border border-white/50 dark:border-white/5 p-6 md:p-8 rounded-2xl md:col-span-3 light-shadow hover:light-shadow dark:shadow-none hover:border-blue-300/50 dark:hover:border-blue-500/20 transition-colors"
		>
			<div class="prose prose-slate dark:prose-invert">
				{
					about.description?.map((paragraph) => (
						<p class="text-base font-normal text-slate-600 dark:text-neutral-300 leading-relaxed">
							<HighlightText text={paragraph.value} keywords={paragraph.keywords} class="font-semibold" />
						</p>
					))
				}
			</div>
		</div>

		{
			about.focus.map((item) => (
				<div class="glass-card bg-white/60 dark:bg-white/5 border border-white/50 dark:border-white/5 p-6 rounded-2xl flex flex-col justify-between group hover:border-blue-300/50 dark:hover:border-blue-500/20 transition-all duration-300 light-shadow hover:light-shadow dark:shadow-none">
					<div class="size-8 rounded bg-linear-to-br from-blue-50 to-white dark:from-blue-500/10 dark:to-transparent flex items-center justify-center text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-500/20 shadow-sm dark:shadow-none duration-300 mb-4">
						<Icon name={item.icon} class="size-5" />
					</div>
					<div>
						<div class="text-2xl font-bold text-foreground tracking-tight">{item.value}</div>
						<div class="text-xs text-muted-foreground uppercase tracking-wider mt-1 font-semibold">
							{item.label}
						</div>
					</div>
				</div>
			))
		}
	</div>
</section>
