---
import HighlightText from '@/components/ui/HighlightText.astro';
import { getLangFromUrl } from '@/utils/language';
import { about as aboutData, getByLang } from '@irfnd/data';
import { Icon } from 'astro-icon/components';

const lang = getLangFromUrl(Astro.url);
const about = getByLang(aboutData, lang);
---

<section data-gsap-slide-up class='scroll-mt-24'>
	<div class='mb-8 flex items-center justify-between'>
		<h2 class='text-foreground text-lg font-semibold tracking-tight'>{about.title}</h2>
		<div class='bg-border ml-6 h-px flex-1'></div>
	</div>

	<div class='grid grid-cols-1 gap-4 md:grid-cols-3' data-gsap-stagger>
		<div
			class='glass-card light-shadow hover:light-shadow rounded-2xl border border-white/50 bg-white/60 p-6 transition-colors hover:border-blue-300/50 md:col-span-3 md:p-8 dark:border-white/5 dark:bg-white/5 dark:shadow-none dark:hover:border-blue-500/20'
		>
			<div class='prose prose-slate dark:prose-invert'>
				{
					about.description?.map((paragraph) => (
						<p class='text-base leading-relaxed font-normal text-slate-600 dark:text-neutral-300'>
							<HighlightText text={paragraph.value} keywords={paragraph.keywords} class='font-semibold' />
						</p>
					))
				}
			</div>
		</div>

		{
			about.focus.map((item) => (
				<div class='glass-card group light-shadow hover:light-shadow flex flex-col justify-between rounded-2xl border border-white/50 bg-white/60 p-6 transition-all duration-300 hover:border-blue-300/50 dark:border-white/5 dark:bg-white/5 dark:shadow-none dark:hover:border-blue-500/20'>
					<div class='mb-4 flex size-8 items-center justify-center rounded border border-blue-100 bg-linear-to-br from-blue-50 to-white text-blue-600 shadow-sm duration-300 dark:border-blue-500/20 dark:from-blue-500/10 dark:to-transparent dark:text-blue-400 dark:shadow-none'>
						<Icon name={item.icon} class='size-5' />
					</div>
					<div>
						<div class='text-foreground text-2xl font-bold tracking-tight'>{item.value}</div>
						<div class='text-muted-foreground mt-1 text-xs font-semibold tracking-wider uppercase'>{item.label}</div>
					</div>
				</div>
			))
		}
	</div>
</section>
