---
// Shared dialog shell for project details.
// Place once in the layout. The project-dialog.ts script populates it
// when a ProjectCard with data-project-id is clicked.
---

<dialog
	data-project-dialog
	class='fixed top-1/2 left-1/2 z-70 m-0 hidden max-h-[90dvh] w-[calc(100%-2rem)] max-w-2xl -translate-x-1/2 -translate-y-1/2 flex-col overflow-hidden rounded-2xl border-none bg-white p-0 shadow-[0_32px_64px_-12px_rgba(0,0,0,0.25)] outline-none backdrop:bg-black/60 backdrop:backdrop-blur-md open:flex dark:bg-neutral-900 dark:shadow-[0_32px_64px_-12px_rgba(0,0,0,0.6)] dark:backdrop:bg-black/75'
>
	<button
		data-dialog-close
		class='absolute top-4 right-4 z-20 cursor-pointer rounded-lg bg-red-500/80 p-1.5 text-white backdrop-blur-sm transition-colors outline-none hover:bg-red-600 focus-visible:ring focus-visible:ring-red-400'
		aria-label='Close dialog'
	>
		<svg class='size-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round'
			><line x1='18' y1='6' x2='6' y2='18'></line><line x1='6' y1='6' x2='18' y2='18'></line></svg
		>
	</button>

	<div data-dialog-content class='flex max-h-[90dvh] min-h-0 flex-col overflow-hidden'></div>
</dialog>
