---
import { Icon } from 'astro-icon/components';
import { cn } from '@/utils/cn';
import { cloudinaryResize } from '@/utils/cloudinary';

import HighlightText from '@/components/ui/HighlightText.astro';
import TechIcon from '@/components/ui/TechIcon.astro';

interface Props {
	name: string;
	icon: string;
	type: 'public' | 'private';
	category: string;
	summary: Array<{ value: string; keywords: string[] }>;
	image: Array<{ url: string; alt: string }>;
	stacks: Array<{
		label: string;
		url: string;
		icon: string;
		color?: string;
		border?: string;
		customColor?: boolean;
	}>;
	source?: string | null;
	demo?: string | null;
	isFirst?: boolean;
	commonLabels: { source: string; liveDemo: string; internal: string };
	dialogId: string;
}

const { name, icon, type, summary, image, stacks, source, demo, isFirst, commonLabels, dialogId } = Astro.props;

const hasImages = image.length > 0;
---

{
	isFirst ? (
		<div
			data-project-id={dialogId}
			class="group relative glass-card bg-white/70 dark:bg-white/5 border border-white/50 dark:border-white/5 rounded-2xl overflow-hidden hover:border-blue-300/60 dark:hover:border-blue-500/30 transition-all duration-300 light-shadow hover:light-shadow-hover dark:shadow-none h-full cursor-pointer"
		>
			<div class="grid md:grid-cols-2 h-full">
				<div class="p-8 flex flex-col justify-between md:h-full relative z-10">
					<div>
						<div class="flex items-start md:items-center gap-3 mb-4">
							<div class="size-8 shrink-0 rounded bg-linear-to-br from-blue-50 to-white dark:from-blue-500/10 dark:to-transparent flex items-center justify-center text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-500/20 shadow-sm dark:shadow-none duration-300">
								<Icon name={icon} class="size-4" />
							</div>
							<h3 class="text-xl font-bold text-foreground">{name}</h3>
						</div>

						<p class="text-sm text-muted-foreground leading-relaxed mb-4 transition-colors">
							<HighlightText text={summary[0].value} keywords={summary[0].keywords} />
						</p>
					</div>

					<div class="space-y-6">
						{stacks.length > 0 && (
							<div class="flex gap-2 flex-wrap mt-auto">
								{stacks.map((stack) => (
									<TechIcon {...stack} class="[&>svg]:size-4 md:[&>svg]:size-5 p-2 rounded-md" />
								))}
							</div>
						)}

						{type === 'public' && (
							<div class="flex gap-5">
								{source && (
									<a
										href={source}
										target="_blank"
										rel="noopener noreferrer"
										class="text-xs font-medium text-foreground flex items-center gap-1 hover:text-blue-600 dark:hover:text-blue-400 transition-colors rounded-sm outline-none focus-visible:ring focus-visible:ring-blue-400 dark:focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-neutral-900"
										onclick="event.stopPropagation()"
									>
										{commonLabels.source} <Icon name="tabler:brand-github" class="size-3" />
									</a>
								)}

								{demo && (
									<a
										href={demo}
										target="_blank"
										rel="noopener noreferrer"
										class="text-xs font-medium text-foreground flex items-center gap-1 hover:text-blue-600 dark:hover:text-blue-400 transition-colors rounded-sm outline-none focus-visible:ring focus-visible:ring-blue-400 dark:focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-neutral-900"
										onclick="event.stopPropagation()"
									>
										{commonLabels.liveDemo} <Icon name="tabler:arrow-up-right" class="size-3" />
									</a>
								)}
							</div>
						)}
					</div>
				</div>

				<div class="relative bg-slate-50/50 dark:bg-neutral-900/50 border-t md:border-t-0 md:border-l border-white/60 dark:border-white/5 h-72 md:h-auto overflow-hidden">
					<div class="pattern-grid absolute inset-0 opacity-50" />
					{type === 'private' && (
						<span class="absolute right-8 top-4 md:top-5 text-[10px] size-fit font-mono font-semibold px-2.5 py-1 rounded-md text-muted-foreground bg-white dark:bg-neutral-900 border border-border dark:border-neutral-800 group-hover:text-blue-700 group-hover:dark:text-blue-400/90 group-hover:bg-blue-50 group-hover:dark:bg-neutral-900/60 group-hover:border group-hover:border-blue-100 group-hover:dark:border-blue-500/20 shadow-sm dark:shadow-none">
							{commonLabels.internal}
						</span>
					)}

					{hasImages ? (
						<div class="absolute h-fit inset-x-8 top-8 bottom-0 bg-card rounded-t-xl border border-border/60 dark:border-neutral-800 shadow-xl transform translate-y-8 group-hover:translate-y-6 transition-transform duration-500">
							<div class="h-10 border-b border-border/50 dark:border-neutral-800 flex items-center px-4 justify-between bg-slate-50/50 dark:bg-transparent">
								<div class="flex gap-1.5">
									<div class="w-2 h-2 rounded-full bg-red-400/80 border border-red-500/20" />
									<div class="w-2 h-2 rounded-full bg-amber-400/80 border border-amber-500/20" />
									<div class="w-2 h-2 rounded-full bg-blue-400/80 border border-blue-500/20" />
								</div>
								<div class="h-1.5 w-16 bg-slate-100 dark:bg-neutral-800 rounded-full" />
							</div>
							<div class="p-4">
								<img
									src={cloudinaryResize(image[0].url, 1000)}
									alt={image[0].alt}
									width={1000}
									height={457}
									loading="lazy"
									class="rounded h-fit"
								/>
							</div>
						</div>
					) : (
						<div class="absolute inset-x-8 top-8 bottom-0 bg-card rounded-t-xl border border-border/60 dark:border-neutral-800 shadow-xl transform translate-y-8 group-hover:translate-y-6 transition-transform duration-500">
							<div class="h-10 border-b border-border/50 dark:border-neutral-800 flex items-center px-4 justify-between bg-slate-50/50 dark:bg-transparent">
								<div class="flex gap-1.5">
									<div class="w-2 h-2 rounded-full bg-red-400/80 border border-red-500/20" />
									<div class="w-2 h-2 rounded-full bg-amber-400/80 border border-amber-500/20" />
									<div class="w-2 h-2 rounded-full bg-blue-400/80 border border-blue-500/20" />
								</div>
								<div class="h-1.5 w-16 bg-slate-100 dark:bg-neutral-800 rounded-full" />
							</div>
							<div class="p-5 grid grid-cols-4 gap-4">
								<div class="col-span-1 h-32 bg-blue-50/50 dark:bg-blue-500/5 rounded border border-blue-100 dark:border-blue-500/10" />
								<div class="col-span-3 space-y-3">
									<div class="h-8 bg-slate-50 dark:bg-neutral-800 rounded w-full" />
									<div class="h-20 bg-slate-50/50 dark:bg-neutral-900 rounded border border-slate-50 dark:border-neutral-800" />
								</div>
							</div>
						</div>
					)}
				</div>
			</div>
		</div>
	) : (
		<div
			data-project-id={dialogId}
			class="group glass-card bg-white/70 dark:bg-white/5 border border-white/50 dark:border-white/5 rounded-2xl relative overflow-hidden hover:border-blue-300/60 dark:hover:border-blue-500/30 transition-all duration-300 flex flex-col justify-between light-shadow hover:light-shadow dark:shadow-none h-full cursor-pointer"
		>
			{hasImages && (
				<div class="absolute inset-0 z-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
					<img
						src={cloudinaryResize(image[0].url, 800)}
						alt={image[0].alt}
						width={800}
						height={365}
						loading="lazy"
						class="size-full object-cover object-left"
					/>
					<div class="absolute inset-0 bg-neutral-700/90 dark:bg-neutral-950/85" />
				</div>
			)}

			<div class="p-6 relative z-10 flex flex-col h-full justify-between">
				<div>
					<div class="flex justify-between items-start mb-4">
						<div class="size-8 rounded bg-linear-to-br from-blue-50 to-white dark:from-blue-500/10 dark:to-transparent dark:group-hover:bg-neutral-900 flex items-center justify-center text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-500/20 shadow-sm dark:shadow-none duration-300">
							<Icon name={icon} class="size-5" />
						</div>

						{type === 'public' ? (
							<div class="flex gap-1">
								{source && (
									<a
										href={source}
										target="_blank"
										rel="noopener noreferrer"
										aria-label={commonLabels.source}
										class="p-1.5 text-slate-400 hover:text-slate-900 dark:hover:text-white group-hover:text-white/80 group-hover:hover:text-white outline-none focus-visible:ring focus-visible:ring-blue-400 dark:focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-neutral-900 transition-colors rounded-lg"
										onclick="event.stopPropagation()"
									>
										<Icon name="tabler:brand-github" class="size-4" />
									</a>
								)}
								{demo && (
									<a
										href={demo}
										target="_blank"
										rel="noopener noreferrer"
										aria-label={commonLabels.liveDemo}
										class="p-1.5 text-slate-400 hover:text-slate-900 dark:hover:text-white group-hover:text-white/80 group-hover:hover:text-white outline-none focus-visible:ring focus-visible:ring-blue-400 dark:focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-neutral-900 transition-colors rounded-lg"
										onclick="event.stopPropagation()"
									>
										<Icon name="tabler:arrow-up-right" class="size-4" />
									</a>
								)}
							</div>
						) : (
							<span class="text-[10px] size-fit font-mono font-semibold px-2.5 py-1 rounded-md text-muted-foreground bg-white dark:bg-neutral-900 border border-border dark:border-neutral-800 group-hover:text-blue-700 group-hover:dark:text-blue-400/90 group-hover:bg-blue-50 group-hover:dark:bg-neutral-900/60 group-hover:border group-hover:border-blue-100 group-hover:dark:border-blue-500/20 shadow-sm dark:shadow-none duration-300">
								{commonLabels.internal}
							</span>
						)}
					</div>

					<h3 class="text-base font-bold text-foreground mb-2 group-hover:text-white transition-colors">
						{name}
					</h3>

					<p class="text-sm text-muted-foreground leading-relaxed mb-4 group-hover:text-neutral-200 transition-colors">
						<HighlightText text={summary[0].value} keywords={summary[0].keywords} />
					</p>
				</div>

				<div class="flex gap-2 items-center mt-auto pt-4 border-t border-border/50 dark:border-neutral-800/50 group-hover:border-white/10 transition-colors">
					{stacks.length > 0 && (
						<div class="flex gap-2 flex-wrap">
							{stacks.map((stack) => (
								<TechIcon {...stack} class="[&>svg]:size-4 md:[&>svg]:size-5 p-2 rounded-md" />
							))}
						</div>
					)}
				</div>
			</div>
		</div>
	)
}
