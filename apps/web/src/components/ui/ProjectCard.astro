---
import { Icon } from 'astro-icon/components';
import { cloudinaryResize } from '@/utils/cloudinary';

import HighlightText from '@/components/ui/HighlightText.astro';
import TechIcon from '@/components/ui/TechIcon.astro';

interface Props {
	name: string;
	icon: string;
	type: 'public' | 'private';
	category: string;
	summary: Array<{ value: string; keywords: string[] }>;
	image: Array<{ url: string; alt: string }>;
	stacks: Array<{
		label: string;
		url: string;
		icon: string;
		color?: string;
		border?: string;
		customColor?: boolean;
	}>;
	source?: string | null;
	demo?: string | null;
	isFirst?: boolean;
	commonLabels: { source: string; liveDemo: string; internal: string };
	dialogId: string;
}

const { name, icon, type, summary, image, stacks, source, demo, isFirst, commonLabels, dialogId } = Astro.props;

const hasImages = image.length > 0;
---

{
	isFirst ? (
		<div
			data-project-id={dialogId}
			class='group glass-card light-shadow hover:light-shadow-hover relative h-full cursor-pointer overflow-hidden rounded-2xl border border-white/50 bg-white/70 transition-all duration-300 hover:border-blue-300/60 dark:border-white/5 dark:bg-white/5 dark:shadow-none dark:hover:border-blue-500/30'
		>
			<div class='grid h-full md:grid-cols-2'>
				<div class='relative z-10 flex flex-col justify-between p-8 md:h-full'>
					<div>
						<div class='mb-4 flex items-start gap-3 md:items-center'>
							<div class='flex size-8 shrink-0 items-center justify-center rounded border border-blue-100 bg-linear-to-br from-blue-50 to-white text-blue-600 shadow-sm duration-300 dark:border-blue-500/20 dark:from-blue-500/10 dark:to-transparent dark:text-blue-400 dark:shadow-none'>
								<Icon name={icon} class='size-4' />
							</div>
							<h3 class='text-foreground text-xl font-bold'>{name}</h3>
						</div>

						<p class='text-muted-foreground mb-4 text-sm leading-relaxed transition-colors'>
							<HighlightText text={summary[0].value} keywords={summary[0].keywords} />
						</p>
					</div>

					<div class='space-y-6'>
						{stacks.length > 0 && (
							<div class='mt-auto flex flex-wrap gap-2'>
								{stacks.map((stack) => (
									<TechIcon {...stack} class='rounded-md p-2 [&>svg]:size-4 md:[&>svg]:size-5' />
								))}
							</div>
						)}

						{type === 'public' && (
							<div class='flex gap-5'>
								{source && (
									<a
										href={source}
										target='_blank'
										rel='noopener noreferrer'
										class='text-foreground flex items-center gap-1 rounded-sm text-xs font-medium transition-colors outline-none hover:text-blue-600 focus-visible:ring focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:hover:text-blue-400 dark:focus-visible:ring-blue-500 dark:focus-visible:ring-offset-neutral-900'
										data-stop-propagation
									>
										{commonLabels.source} <Icon name='tabler:brand-github' class='size-3' />
									</a>
								)}

								{demo && (
									<a
										href={demo}
										target='_blank'
										rel='noopener noreferrer'
										class='text-foreground flex items-center gap-1 rounded-sm text-xs font-medium transition-colors outline-none hover:text-blue-600 focus-visible:ring focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:hover:text-blue-400 dark:focus-visible:ring-blue-500 dark:focus-visible:ring-offset-neutral-900'
										data-stop-propagation
									>
										{commonLabels.liveDemo} <Icon name='tabler:arrow-up-right' class='size-3' />
									</a>
								)}
							</div>
						)}
					</div>
				</div>

				<div class='relative h-72 overflow-hidden border-t border-white/60 bg-slate-50/50 md:h-auto md:border-t-0 md:border-l dark:border-white/5 dark:bg-neutral-900/50'>
					<div class='pattern-grid absolute inset-0 opacity-50' />
					{type === 'private' && (
						<span class='text-muted-foreground border-border absolute top-4 right-8 size-fit rounded-md border bg-white px-2.5 py-1 font-mono text-[10px] font-semibold shadow-sm group-hover:border group-hover:border-blue-100 group-hover:bg-blue-50 group-hover:text-blue-700 md:top-5 dark:border-neutral-800 dark:bg-neutral-900 dark:shadow-none group-hover:dark:border-blue-500/20 group-hover:dark:bg-neutral-900/60 group-hover:dark:text-blue-400/90'>
							{commonLabels.internal}
						</span>
					)}

					{hasImages ? (
						<div class='bg-card border-border/60 absolute inset-x-8 top-8 bottom-0 h-fit translate-y-8 transform rounded-t-xl border shadow-xl transition-transform duration-500 group-hover:translate-y-6 dark:border-neutral-800'>
							<div class='border-border/50 flex h-10 items-center justify-between border-b bg-slate-50/50 px-4 dark:border-neutral-800 dark:bg-transparent'>
								<div class='flex gap-1.5'>
									<div class='h-2 w-2 rounded-full border border-red-500/20 bg-red-400/80' />
									<div class='h-2 w-2 rounded-full border border-amber-500/20 bg-amber-400/80' />
									<div class='h-2 w-2 rounded-full border border-blue-500/20 bg-blue-400/80' />
								</div>
								<div class='h-1.5 w-16 rounded-full bg-slate-100 dark:bg-neutral-800' />
							</div>
							<div class='p-4'>
								<img
									src={cloudinaryResize(image[0].url, 1000)}
									alt={image[0].alt}
									width={1000}
									height={457}
									loading='lazy'
									class='h-fit rounded'
								/>
							</div>
						</div>
					) : (
						<div class='bg-card border-border/60 absolute inset-x-8 top-8 bottom-0 translate-y-8 transform rounded-t-xl border shadow-xl transition-transform duration-500 group-hover:translate-y-6 dark:border-neutral-800'>
							<div class='border-border/50 flex h-10 items-center justify-between border-b bg-slate-50/50 px-4 dark:border-neutral-800 dark:bg-transparent'>
								<div class='flex gap-1.5'>
									<div class='h-2 w-2 rounded-full border border-red-500/20 bg-red-400/80' />
									<div class='h-2 w-2 rounded-full border border-amber-500/20 bg-amber-400/80' />
									<div class='h-2 w-2 rounded-full border border-blue-500/20 bg-blue-400/80' />
								</div>
								<div class='h-1.5 w-16 rounded-full bg-slate-100 dark:bg-neutral-800' />
							</div>
							<div class='grid grid-cols-4 gap-4 p-5'>
								<div class='col-span-1 h-32 rounded border border-blue-100 bg-blue-50/50 dark:border-blue-500/10 dark:bg-blue-500/5' />
								<div class='col-span-3 space-y-3'>
									<div class='h-8 w-full rounded bg-slate-50 dark:bg-neutral-800' />
									<div class='h-20 rounded border border-slate-50 bg-slate-50/50 dark:border-neutral-800 dark:bg-neutral-900' />
								</div>
							</div>
						</div>
					)}
				</div>
			</div>
		</div>
	) : (
		<div
			data-project-id={dialogId}
			class='group glass-card light-shadow hover:light-shadow relative flex h-full cursor-pointer flex-col justify-between overflow-hidden rounded-2xl border border-white/50 bg-white/70 transition-all duration-300 hover:border-blue-300/60 dark:border-white/5 dark:bg-white/5 dark:shadow-none dark:hover:border-blue-500/30'
		>
			{hasImages && (
				<div class='absolute inset-0 z-0 opacity-0 transition-opacity duration-500 group-hover:opacity-100'>
					<img
						src={cloudinaryResize(image[0].url, 800)}
						alt={image[0].alt}
						width={800}
						height={365}
						loading='lazy'
						class='size-full object-cover object-left'
					/>
					<div class='absolute inset-0 bg-neutral-700/90 dark:bg-neutral-950/85' />
				</div>
			)}

			<div class='relative z-10 flex h-full flex-col justify-between p-6'>
				<div>
					<div class='mb-4 flex items-start justify-between'>
						<div class='flex size-8 items-center justify-center rounded border border-blue-100 bg-linear-to-br from-blue-50 to-white text-blue-600 shadow-sm duration-300 dark:border-blue-500/20 dark:from-blue-500/10 dark:to-transparent dark:text-blue-400 dark:shadow-none dark:group-hover:bg-neutral-900'>
							<Icon name={icon} class='size-5' />
						</div>

						{type === 'public' ? (
							<div class='flex gap-1'>
								{source && (
									<a
										href={source}
										target='_blank'
										rel='noopener noreferrer'
										aria-label={commonLabels.source}
										class='rounded-lg p-1.5 text-slate-400 transition-colors outline-none group-hover:text-white/80 hover:text-slate-900 group-hover:hover:text-white focus-visible:ring focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:hover:text-white dark:focus-visible:ring-blue-500 dark:focus-visible:ring-offset-neutral-900'
										data-stop-propagation
									>
										<Icon name='tabler:brand-github' class='size-4' />
									</a>
								)}
								{demo && (
									<a
										href={demo}
										target='_blank'
										rel='noopener noreferrer'
										aria-label={commonLabels.liveDemo}
										class='rounded-lg p-1.5 text-slate-400 transition-colors outline-none group-hover:text-white/80 hover:text-slate-900 group-hover:hover:text-white focus-visible:ring focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:hover:text-white dark:focus-visible:ring-blue-500 dark:focus-visible:ring-offset-neutral-900'
										data-stop-propagation
									>
										<Icon name='tabler:arrow-up-right' class='size-4' />
									</a>
								)}
							</div>
						) : (
							<span class='text-muted-foreground border-border size-fit rounded-md border bg-white px-2.5 py-1 font-mono text-[10px] font-semibold shadow-sm duration-300 group-hover:border group-hover:border-blue-100 group-hover:bg-blue-50 group-hover:text-blue-700 dark:border-neutral-800 dark:bg-neutral-900 dark:shadow-none group-hover:dark:border-blue-500/20 group-hover:dark:bg-neutral-900/60 group-hover:dark:text-blue-400/90'>
								{commonLabels.internal}
							</span>
						)}
					</div>

					<h3 class='text-foreground mb-2 text-base font-bold transition-colors group-hover:text-white'>{name}</h3>

					<p class='text-muted-foreground mb-4 text-sm leading-relaxed transition-colors group-hover:text-neutral-200'>
						<HighlightText text={summary[0].value} keywords={summary[0].keywords} />
					</p>
				</div>

				<div class='border-border/50 mt-auto flex items-center gap-2 border-t pt-4 transition-colors group-hover:border-white/10 dark:border-neutral-800/50'>
					{stacks.length > 0 && (
						<div class='flex flex-wrap gap-2'>
							{stacks.map((stack) => (
								<TechIcon {...stack} class='rounded-md p-2 [&>svg]:size-4 md:[&>svg]:size-5' />
							))}
						</div>
					)}
				</div>
			</div>
		</div>
	)
}

<script>
	document.addEventListener('click', (e) => {
		const el = (e.target as HTMLElement).closest('[data-stop-propagation]');
		if (el) e.stopPropagation();
	});
</script>
