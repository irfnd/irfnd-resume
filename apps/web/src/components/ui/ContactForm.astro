---
import { Icon } from 'astro-icon/components';
import { cn } from '@/utils/cn';

interface IFormField {
	label: string;
	name: string;
	type: 'text' | 'email' | 'tel' | 'textarea';
	placeholder: string;
}

interface IContactValidation {
	fullName: { min: string; max: string };
	email: { invalid: string };
	telephone: { min: string; max: string };
	subject: { min: string; max: string };
	message: { min: string; max: string };
}

interface Props {
	formFields: IFormField[];
	contactMe: {
		formTitle: string;
		submitButton: string;
		submittingButton: string;
		successMessage: string;
		sendAnotherMessage: string;
		errors: Record<string, string>;
		reachMeDirectly: string;
	};
	validation: IContactValidation;
	directContact: Array<{ label: string; url: string; icon: string }>;
}

const { formFields, contactMe, validation, directContact } = Astro.props;
---

<div
	class='glass-card light-shadow relative flex flex-col gap-6 rounded-3xl border border-white/50 bg-white/60 p-6 md:p-8 dark:border-white/5 dark:bg-white/5 dark:shadow-none'
>
	<h3 class='text-foreground text-lg font-bold'>{contactMe.formTitle}</h3>

	<div
		class='bg-background/95 absolute inset-0 z-20 hidden flex-col items-center justify-center space-y-4 rounded-3xl p-8 text-center backdrop-blur-md'
		data-contact-success
	>
		<div class='flex h-16 w-16 items-center justify-center rounded-full bg-green-500/10 text-green-500'>
			<Icon name='tabler:check' class='size-8' />
		</div>
		<h4 class='text-foreground text-lg font-bold'>{contactMe.successMessage}</h4>
		<button type='button' class='text-primary cursor-pointer text-sm font-medium hover:underline' data-contact-reset>
			{contactMe.sendAnotherMessage}
		</button>
	</div>

	<form
		data-contact-form
		data-validation={JSON.stringify(validation)}
		data-errors={JSON.stringify(contactMe.errors)}
		data-success-message={contactMe.successMessage}
		class='flex flex-col gap-6'
	>
		<div class='grid grid-cols-1 gap-6 md:grid-cols-2'>
			{
				formFields.map((field) => {
					const isTextarea = field.type === 'textarea';
					return (
						<div class={cn('flex flex-col gap-2', isTextarea && 'md:col-span-2')}>
							<label for={field.name} class='text-foreground w-fit cursor-pointer text-sm font-semibold'>
								{field.label}
							</label>

							{isTextarea ? (
								<textarea
									id={field.name}
									name={field.name}
									rows={5}
									placeholder={field.placeholder}
									class='bg-background/50 border-border focus:border-primary focus:ring-primary/10 placeholder:text-muted-foreground/40 text-foreground w-full resize-none rounded-xl border px-4 py-3 text-base transition-all outline-none focus:ring-2'
									data-field={field.name}
								/>
							) : (
								<input
									id={field.name}
									name={field.name}
									type={field.type as astroHTML.JSX.HTMLInputTypeAttribute}
									placeholder={field.placeholder}
									class='bg-background/50 border-border focus:border-primary focus:ring-primary/10 placeholder:text-muted-foreground/40 text-foreground h-12 w-full rounded-xl border px-4 text-base transition-all outline-none focus:ring-2'
									data-field={field.name}
								/>
							)}

							<span class='hidden text-xs text-red-500' data-field-error={field.name} />
						</div>
					);
				})
			}
		</div>

		<button
			type='submit'
			data-submit-btn
			class='bg-primary group flex h-12 w-full cursor-pointer items-center justify-center gap-2 rounded-xl px-6 text-base font-semibold text-white shadow-none transition-all hover:opacity-90 active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-70 lg:ml-auto lg:w-auto'
		>
			<span data-submit-text>{contactMe.submitButton}</span>
			<span class='hidden items-center gap-2' data-loading-text>
				<Icon name='tabler:loader-2' class='size-5 animate-spin' />
				{contactMe.submittingButton}
			</span>
		</button>
	</form>

	<div class='bg-border h-px w-full'></div>

	<div class='grid grid-cols-1 gap-6 md:grid-cols-2'>
		<div class='flex flex-col gap-6'>
			<h2 class='text-foreground text-lg font-semibold'>{contactMe.reachMeDirectly}</h2>
			<div class='flex flex-col gap-3' data-gsap-stagger>
				{
					directContact.map((item) => (
						<a
							href={item.url}
							target='_blank'
							rel='noopener noreferrer'
							class='group text-muted-foreground focus-visible:ring-offset-background flex w-fit items-center gap-2 rounded-sm text-xs transition-colors outline-none hover:text-blue-600 focus-visible:ring focus-visible:ring-blue-400 focus-visible:ring-offset-2 dark:hover:text-white dark:focus-visible:ring-blue-500'
						>
							<Icon
								name={item.icon}
								class='text-muted-foreground/70 size-3.5 transition-colors group-hover:text-blue-600 dark:group-hover:text-blue-400'
							/>
							{item.label}
						</a>
					))
				}
			</div>
		</div>

		<slot name='map' />
	</div>
</div>

<script>
	function initSuccessOverlay() {
		const successEl = document.querySelector('[data-contact-success]');
		const resetBtn = document.querySelector('[data-contact-reset]');

		if (!successEl || !resetBtn) return;

		resetBtn.addEventListener('click', () => {
			successEl.classList.add('hidden');
			successEl.classList.remove('flex');
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initSuccessOverlay);
	} else {
		initSuccessOverlay();
	}
</script>
