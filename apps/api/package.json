{
	"name": "@irfnd/api",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "bun@1.3.10",
	"scripts": {
		"dev": "bun run --hot src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun --minify",
		"start": "bun run dist/index.js",
		"lint": "eslint .",
		"format": "prettier --write .",
		"test": "vitest",
		"test:ui": "vitest --ui --coverage",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf .turbo dist"
	},
	"dependencies": {
		"@irfnd/data": "workspace:*",
		"@irfnd/schemas": "workspace:*",
		"hono": "^4.12.3",
		"puppeteer": "^24.40.0",
		"resend": "^6.9.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@irfnd/prettier-config": "^1.4.0",
		"@types/bun": "^1.3.10",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"eslint": "^10.0.2",
		"prettier": "^3.8.1",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.56.1",
		"vitest": "^4.0.18"
	}
}
