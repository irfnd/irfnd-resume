{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"jsx": "react-jsx",
		"lib": ["ES2022"],
		"types": ["bun"],
		"paths": { "@/*": ["./src/*"] }
	},
	"include": ["src", "tests"],
	"exclude": ["node_modules", "dist"]
}
