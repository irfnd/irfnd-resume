{
	"name": "irfnd-resume",
	"private": true,
	"packageManager": "bun@1.3.10",
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"prepare": "husky",
		"dev": "turbo run dev",
		"build": "turbo run build",
		"lint": "turbo run lint",
		"format": "turbo run format",
		"format:root": "prettier --write \"*.{js,json,md}\"",
		"test": "turbo run test",
		"test:ui": "turbo run test:ui",
		"test:run": "turbo run test:run",
		"test:coverage": "turbo run test:coverage",
		"clean": "turbo run clean"
	},
	"devDependencies": {
		"@irfnd/prettier-config": "^1.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.1",
		"prettier": "^3.8.1",
		"turbo": "^2.8.12"
	}
}
